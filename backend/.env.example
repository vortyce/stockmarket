# App Settings
APP_NAME="B3 Screener API"
ENVIRONMENT="dev"

# Database (PostgreSQL)
# Se estiver rodando via Docker, o host deve ser 'db'
DATABASE_URL="postgresql://postgres:postgres@db:5432/b3screener"

# Cache (Redis)
REDIS_URL="redis://redis:6379/0"

# CORS
CORS_ORIGINS="http://localhost:3000"

# Providers - OpLab
OPLAB_API_BASE_URL=https://api.oplab.com.br/v3
OPLAB_API_TOKEN=your_token_here
